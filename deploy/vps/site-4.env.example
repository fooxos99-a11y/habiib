NODE_ENV=production
APP_PORT=3004

# Target project: db.xhfddytzyxplsuxdduqb.supabase.co
# Fill the real Supabase keys for the second site before deployment.
NEXT_PUBLIC_SUPABASE_URL=https://xhfddytzyxplsuxdduqb.supabase.co
SUPABASE_URL=https://xhfddytzyxplsuxdduqb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_site_4_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_site_4_service_role_key

# Generate unique secrets for this site. Do not reuse values from another site.
AUTH_SESSION_SECRET=your_site_4_auth_session_secret
CRON_SECRET=your_site_4_cron_secret

# Dedicated WhatsApp Web worker paths for site 4.
WHATSAPP_CLIENT_ID=habib-site-4
WHATSAPP_AUTH_DIR=/var/www/habib/shared/site-4/.wwebjs_auth
WHATSAPP_STATUS_FILE_PATH=/var/www/habib/shared/site-4/whatsapp-status.json
WHATSAPP_QR_IMAGE_PATH=/var/www/habib/shared/site-4/whatsapp-qr.png
WHATSAPP_COMMAND_FILE_PATH=/var/www/habib/shared/site-4/whatsapp-command.json
WHATSAPP_LOCK_FILE_PATH=/var/www/habib/shared/site-4/whatsapp-worker.lock

# Optional when Chromium is installed outside the default PATH.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser