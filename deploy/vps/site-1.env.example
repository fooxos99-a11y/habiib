NODE_ENV=production
APP_PORT=3001

NEXT_PUBLIC_SUPABASE_URL=https://your-site-1-project.supabase.co
SUPABASE_URL=https://your-site-1-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_site_1_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_site_1_service_role_key

WHATSAPP_CLIENT_ID=habib-site-1
WHATSAPP_AUTH_DIR=/var/www/habib/shared/site-1/.wwebjs_auth
WHATSAPP_STATUS_FILE_PATH=/var/www/habib/shared/site-1/whatsapp-status.json
WHATSAPP_QR_IMAGE_PATH=/var/www/habib/shared/site-1/whatsapp-qr.png
WHATSAPP_COMMAND_FILE_PATH=/var/www/habib/shared/site-1/whatsapp-command.json
WHATSAPP_LOCK_FILE_PATH=/var/www/habib/shared/site-1/whatsapp-worker.lock

# Optional when Chromium is installed outside the default PATH.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser