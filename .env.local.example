# WhatsApp Cloud API Configuration
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_verification_token_here
WHATSAPP_API_VERSION=v19.0

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Web Push (VAPID)
WEB_PUSH_SUBJECT=mailto:notifications@example.com
WEB_PUSH_PRIVATE_KEY=your_web_push_private_key
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=your_web_push_public_key
